# Database
# Render/production can use a single DATABASE_URL instead of the fields below
DATABASE_URL=
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=masmercat
DATABASE_PASSWORD=your_secure_password
DATABASE_NAME=masmercat_db
TYPEORM_SYNCHRONIZE=false

# JWT
JWT_SECRET=your_jwt_secret_key_change_this_in_production
JWT_EXPIRATION=7d

# AWS S3
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=eu-west-1
AWS_S3_BUCKET=masmercat-images

# OpenAI
OPENAI_API_KEY=your_openai_api_key

# Optional external ML vision detector
ML_VISION_ENDPOINT=
ML_VISION_API_KEY=
ML_VISION_TIMEOUT_MS=8000
ML_VISION_MIN_CONFIDENCE=0.45
ML_VISION_PREFER_DETECTOR=true

# Email (Optional - for notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_email_password

# App
PORT=3000
NODE_ENV=development
FRONTEND_URL=http://localhost:3001
ADMIN_URL=http://localhost:3002
